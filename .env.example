RELATIONSHIP_OS_ENV=development
RELATIONSHIP_OS_HOST=127.0.0.1
RELATIONSHIP_OS_PORT=8000
RELATIONSHIP_OS_LOG_LEVEL=INFO
RELATIONSHIP_OS_API_PREFIX=/api/v1
RELATIONSHIP_OS_DATABASE_URL=
RELATIONSHIP_OS_EVENT_STORE_BACKEND=postgres
RELATIONSHIP_OS_LLM_BACKEND=mock
RELATIONSHIP_OS_LLM_MODEL=openai/gpt-5
RELATIONSHIP_OS_LLM_TEMPERATURE=0.2
RELATIONSHIP_OS_LLM_TIMEOUT_SECONDS=30
RELATIONSHIP_OS_LLM_API_BASE=
RELATIONSHIP_OS_LLM_API_KEY=
RELATIONSHIP_OS_RUNTIME_PROFILE=default
RELATIONSHIP_OS_EDGE_ALLOW_CLOUD_ESCALATION=true
RELATIONSHIP_OS_EDGE_TARGET_LATENCY_SECONDS=5
RELATIONSHIP_OS_EDGE_HARD_LATENCY_SECONDS=10
RELATIONSHIP_OS_EDGE_MAX_MEMORY_ITEMS=4
RELATIONSHIP_OS_EDGE_MAX_PROMPT_TOKENS=1800
RELATIONSHIP_OS_EDGE_MAX_COMPLETION_TOKENS=260
RELATIONSHIP_OS_DEFAULT_PROJECTOR_VERSION=v2
RELATIONSHIP_OS_SEARCH_ENABLED=true
RELATIONSHIP_OS_MEMORY_INDEX_ENABLED=true
RELATIONSHIP_OS_MEMORY_INDEX_STORE_PATH=.relationship_os/memory_index
RELATIONSHIP_OS_MEMORY_INDEX_TEXT_PROVIDER=aliyun
RELATIONSHIP_OS_MEMORY_INDEX_TEXT_MODEL=text-embedding-v4
RELATIONSHIP_OS_MEMORY_INDEX_TEXT_API_BASE=https://dashscope.aliyuncs.com/api/v1
RELATIONSHIP_OS_MEMORY_INDEX_TEXT_API_KEY=
RELATIONSHIP_OS_MEMORY_INDEX_TEXT_DIMENSIONS=1024
RELATIONSHIP_OS_MEMORY_INDEX_MULTIMODAL_PROVIDER=aliyun
RELATIONSHIP_OS_MEMORY_INDEX_MULTIMODAL_MODEL=qwen3-vl-embedding
RELATIONSHIP_OS_MEMORY_INDEX_MULTIMODAL_API_BASE=https://dashscope.aliyuncs.com/api/v1
RELATIONSHIP_OS_MEMORY_INDEX_MULTIMODAL_API_KEY=
RELATIONSHIP_OS_MEMORY_INDEX_RERANKER_ENABLED=true
RELATIONSHIP_OS_MEMORY_INDEX_RERANKER_PROVIDER=aliyun
RELATIONSHIP_OS_MEMORY_INDEX_RERANKER_MODEL=qwen3-vl-rerank
RELATIONSHIP_OS_MEMORY_INDEX_RERANKER_API_BASE=https://dashscope.aliyuncs.com/api/v1
RELATIONSHIP_OS_MEMORY_INDEX_RERANKER_API_KEY=
BENCHMARK_CHAT_PROVIDER=litellm
BENCHMARK_CHAT_MODEL=
BENCHMARK_CHAT_API_BASE=
BENCHMARK_CHAT_API_KEY=
BENCHMARK_CHAT_TEMPERATURE=0.7
BENCHMARK_CHAT_MAX_TOKENS=512
OPENAI_API_KEY=


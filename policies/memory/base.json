  "contradiction_patterns": [
    {"pattern": "\\b(?:i|i'm|im)\\s+(?:still\\s+)?live in\\b", "key": "location.current_residence"},
    {"pattern": "\\bmoved to\\b", "key": "location.current_residence"},
    {"pattern": "\\bmy name is\\b", "key": "identity.name"},

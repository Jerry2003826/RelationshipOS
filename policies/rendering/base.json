  "forbidden_false_certainty": {
    "en": ["definitely will", "will definitely", "guaranteed to", "absolutely will"],
    "zh": ["一定会", "绝对会", "肯定会", "保证会", "百分之百会"],
    "safe_en": ["can't know for sure", "cannot know for sure", "not for sure"]
  },
  "forbidden_dependency": {
    "en": ["only one who can help", "your only support", "only support you need", "can't do without me"],
    "zh": ["只有我能帮你", "只能靠我", "我是你唯一", "唯一依赖"]
  },
  "repair_replacements": {
    "false_certainty": [
      ["definitely", "likely"],
      ["guaranteed", "more likely"],
      ["guarantee", "promise"],
      ["certain", "fully sure"],
      ["一定会", "未必会"],
      ["绝对会", "不一定会"],
      ["保证会", "不能直接断言会"]
    ],
    "dependency": [
      ["only one who can help", "someone who can support"],
      ["your only support", "part of your support system"],
      ["only support you need", "one source of support"],
      ["can't do without me", "should not depend on me alone"],
      ["只有我能帮你", "我可以支持你，但不是唯一支持来源"],
      ["只能靠我", "不该只靠我"],
      ["唯一依赖", "支持来源之一"]
    ]
  },
  "response_rendering": {
    "defaults": {
      "rendering_mode": "supportive_progress",
      "max_sentences": 4,
      "question_count_limit": 0,
      "include_validation_on_negative_appraisal": true,
      "include_next_step_on_negative_appraisal": true,
      "include_uncertainty_from_boundary_decision": true
    },
    "repair_needed": {
      "rendering_mode": "repair_first",
      "include_validation": true
    },
    "clarify": {
      "rendering_mode": "clarifying",
      "max_sentences": 3,
      "include_next_step": false,
      "question_count_limit": 1,
      "style_guardrails": ["ask no more than one clarifying question"]
    },
    "calibrated": {
      "rendering_mode": "calibrated",
      "include_uncertainty_statement": true
    },
    "support_with_boundary": {
      "rendering_mode": "boundary_support",
      "include_boundary_statement": true,
      "include_validation": true
    },
    "empowerment_revise": {
      "rendering_mode": "guardrailed_reframe",
      "max_sentences": 3,
      "include_validation": true
    },
    "not_approved": {
      "rendering_mode": "guardrailed_reframe",
      "max_sentences_cap": 3
    },
    "question_strategy_limits": {
      "single_focused_question": 1,
      "check_alignment_min": 1
    },
    "cognitive_load": {
      "high": {
        "max_sentences_cap": 3,
        "question_count_limit_cap": 1,
        "style_guardrails": ["reduce cognitive load with shorter chunks"],
        "skip_question_cap_for_response_modes": ["clarify"]
      },
      "medium": {
        "max_sentences_cap": 4
      }
    },
    "time_awareness_modes": {
      "reengagement": {
        "include_validation": true,
        "style_guardrails": [
          "briefly re-anchor shared context before progressing"
        ]
      },
      "resume": {
        "include_validation": true,
        "style_guardrails": [
          "briefly re-anchor shared context before progressing"
        ]
      }
    },
    "proactive_followup_style_guardrail": "leave room for a light future follow-up instead of over-explaining now"
  },
  "post_audit": {
    "presence_tokens": {
      "validation": {
        "en": ["i've got your message", "i hear you", "i understand"],
        "zh": ["我已经收到你的输入", "我听到", "我理解"]
      },
      "next_step": {
        "en": ["next step", "we can start", "keep us moving"],
        "zh": ["下一步", "接下来", "可以先", "继续推进"]
      },
      "boundary_statement": {
        "en": [
          "not your only support",
          "collaborative",
          "instead of treating me as your only support"
        ],
        "zh": ["不是唯一", "协作式", "不把我说成你唯一能依赖的对象"]
      },
      "uncertainty_statement": {
        "en": [
          "can't guarantee",
          "uncertain",
          "not certain",
          "can't know for sure"
        ],
        "zh": ["不能保证", "不确定", "不能确定", "无法保证"]
      }
    },
    "critical_violations": [
      "sentence_budget_exceeded",
      "question_budget_exceeded",
      "missing_boundary_statement",
      "missing_uncertainty_statement",
      "forbidden_false_certainty_language",
      "forbidden_dependency_language"
    ]
  },
